# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA commite o arquivo .env de verdade no Git

# String de conexão do PostgreSQL (Supabase, Render, Railway, ou local)
DATABASE_URL="postgresql://usuario:senha@localhost:5432/ecommerce_db?schema=public"

# Porta da aplicação
PORT=3000

# Ambiente: development | production | test
NODE_ENV=development

# Segredo usado para assinar os tokens JWT — gere um valor aleatório forte
JWT_SECRET="troque-por-uma-string-aleatoria-bem-longa-e-secreta"
JWT_EXPIRES_IN="7d"

# URL pública da API, usada na documentação Swagger
API_URL="http://localhost:3000"

# Origem permitida para CORS (URL do seu frontend)
CORS_ORIGIN="http://localhost:5173"
